# Wallet private key for contract deployment (MetaMask → Fuji testnet)
PRIVATE_KEY=your_private_key_here

# SnowTrace API key for contract verification (optional)
SNOWTRACE_API_KEY=your_api_key_here

# Contract addresses (set after deploying with Hardhat)
VITE_GLADE_TOKEN_ADDRESS=0x_deployed_token_address
VITE_GLADE_FARM_ADDRESS=0x_deployed_farm_address
